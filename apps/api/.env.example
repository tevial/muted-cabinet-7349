OPENAI_API_KEY=
TRANSCRIPTION_PROVIDER=auto
STABLE_TS_MODEL=base
STABLE_TS_VAD=true
STABLE_TS_VAD_THRESHOLD=0.35
STABLE_TS_MIN_WORD_DURATION=0.1
STABLE_TS_NONSPEECH_ERROR=0.1
STABLE_TS_NONSPEECH_SKIP=5.0
MFA_COMMAND=mfa
# Defaults are inferred from LANGUAGE for uk/ru/en. Override these when using a custom model path or saved MFA model name.
MFA_DICTIONARY=
MFA_ACOUSTIC_MODEL=
MFA_G2P_MODEL=
MFA_NUM_JOBS=1
MFA_TIMEOUT_SECONDS=180
MFA_SINGLE_SPEAKER=true
MFA_TEXTGRID_CLEANUP=true
MFA_FINE_TUNE=false
